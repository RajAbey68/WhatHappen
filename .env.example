# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://pomgvxdokjmxyfbgazls.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # from Supabase dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY=           # from Supabase dashboard → Settings → API (keep secret)

# ── OpenRouter (LLM gateway) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=                  # https://openrouter.ai/keys
# Optional: override default model chain
# LLM_MODEL_PRIMARY=deepseek/deepseek-chat-v3-0324
# LLM_MODEL_FALLBACK=anthropic/claude-3-haiku
# LLM_MODEL_EMERGENCY=openai/gpt-4o-mini

# ── GCP (Cloud Storage for large file uploads) ────────────────────────────────
GCS_BUCKET=                          # e.g. whathappen-uploads
# GOOGLE_APPLICATION_CREDENTIALS=   # path to service account JSON (local dev only)

# ── OCR microservice ──────────────────────────────────────────────────────────
# OCR_MICROSERVICE_URL="https://ocr-microservice-gamma.vercel.app"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
